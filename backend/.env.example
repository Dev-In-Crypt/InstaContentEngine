# ============================================================
#  InstaContentEngine — Environment Configuration
#  INSTRUCTIONS:
#    1. Copy this file:  backend\.env.example  →  backend\.env
#    2. Fill in your API keys below
#    3. Only OPENROUTER_API_KEY is required to run the app
# ============================================================

# === OpenRouter (REQUIRED) ===
# Get your key at https://openrouter.ai → Keys → Create Key
OPENROUTER_API_KEY=sk-or-v1-...

# === Default AI models ===
# Any model ID from https://openrouter.ai/models
DEFAULT_TEXT_MODEL=google/gemini-2.5-flash
DEFAULT_IMAGE_MODEL=google/gemini-2.5-flash

# === Stock Photos (optional, free) ===
# Unsplash: https://unsplash.com/developers → New Application → Access Key
UNSPLASH_ACCESS_KEY=...
# Pexels: https://www.pexels.com/api → API Key
PEXELS_API_KEY=...

# === Core (leave as-is for local use) ===
DATABASE_URL=sqlite+aiosqlite:///./insta.db
SECRET_KEY=change-me-in-production
API_TOKEN=

# === Instagram / Meta (optional) ===
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_USER_ID=...
META_APP_ID=...
META_APP_SECRET=...

# === Canva (optional) ===
CANVA_CLIENT_ID=...
CANVA_CLIENT_SECRET=...
CANVA_REDIRECT_URI=http://localhost:8000/auth/canva/callback

# === Telegram Bot (optional) ===
TELEGRAM_BOT_TOKEN=...

# === File Storage (local by default) ===
STORAGE_TYPE=local
STORAGE_PATH=./uploads

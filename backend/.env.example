# ============================================================
#  InstaContentEngine — Environment Configuration
#  INSTRUCTIONS:
#    1. Copy this file:  backend\.env.example  →  backend\.env
#    2. Fill in your API keys below
#    3. Only OPENROUTER_API_KEY is required to run the app
# ============================================================

# === OpenRouter (REQUIRED) ===
# Get your key at https://openrouter.ai → Keys → Create Key
OPENROUTER_API_KEY=sk-or-v1-...

# === Default AI models ===
# Any model ID from https://openrouter.ai/models
DEFAULT_TEXT_MODEL=google/gemini-2.5-flash
DEFAULT_IMAGE_MODEL=google/gemini-2.5-flash

# === Stock Photos (optional, free) ===
# Unsplash: https://unsplash.com/developers → New Application → Access Key
UNSPLASH_ACCESS_KEY=...
# Pexels: https://www.pexels.com/api → API Key
PEXELS_API_KEY=...

# === Core (leave as-is for local use) ===
DATABASE_URL=sqlite+aiosqlite:///./insta.db
SECRET_KEY=change-me-in-production
# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Bearer token guarding every API call. Optional for local use (the app binds to
# 127.0.0.1). REQUIRED in cloud mode (APP_MODE=cloud) — the app refuses to start
# without it, since it would otherwise serve /api/admin/backup to the public.
API_TOKEN=

# Certificates are always checked against your operating system's trust store, so
# an antivirus or corporate proxy that inspects HTTPS (Avast, Kaspersky, ESET,
# Zscaler) works without changing anything here — its root is already installed
# there. Leave this alone.
#
# Setting it false only stops OpenRouter, Unsplash and Pexels from verifying, and
# exposes those API keys to interception. Instagram, imgbb, trend discovery and the
# Telegram bot verify regardless. It is a last resort on a network you trust — not
# the cure for a TLS-inspecting antivirus.
SSL_VERIFY=true

# === Instagram / Meta (optional — required for publishing/scheduling) ===
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_USER_ID=...
META_APP_ID=...
META_APP_SECRET=...

# === X / Twitter (optional — required to publish to X) ===
# OAuth 1.0a user context from developer.x.com (needs a paid Basic tier to post).
# App: Keys and tokens → API Key/Secret + Access Token/Secret (with Read+Write).
X_API_KEY=...
X_API_SECRET=...
X_ACCESS_TOKEN=...
X_ACCESS_TOKEN_SECRET=...

# === Image hosting (required for publishing — IG can't reach 127.0.0.1) ===
# Free key at https://api.imgbb.com  → slides are uploaded here to get public URLs
IMGBB_API_KEY=...

# === Deployment mode ===
# local = desktop app; scheduled posts publish ONLY while the app is open.
# cloud = 24/7 backend (Railway/Render); scheduled posts publish even with PC off.
# See DEPLOY.md for the cloud setup.
APP_MODE=local
PUBLIC_BASE_URL=
# For CLOUD mode use a Postgres DB instead of sqlite, e.g.:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# === Canva (optional) ===
CANVA_CLIENT_ID=...
CANVA_CLIENT_SECRET=...
CANVA_REDIRECT_URI=http://localhost:8000/auth/canva/callback

# === Telegram Bot (optional) ===
TELEGRAM_BOT_TOKEN=...

# === File Storage (local by default) ===
STORAGE_TYPE=local
STORAGE_PATH=./uploads

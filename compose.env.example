# Copy this file to  .env  (same folder as docker-compose.yml) and fill it in.
# .env is gitignored — never commit real secrets.

# Your domain. Its DNS A-record MUST point to this VPS's public IP, and ports
# 80 + 443 must be open, or Caddy can't get an HTTPS certificate.
DOMAIN=engine.example.com

# Strong, STABLE secret. Signs login tokens AND derives the key that encrypts
# every user's stored API keys. NEVER change it after go-live (rotating it logs
# everyone out and makes all stored keys undecryptable).
# Generate one:  openssl rand -base64 48
SECRET_KEY=

# Postgres password (any strong random string).
DB_PASSWORD=

# Your email(s), comma-separated → granted admin (DB backup/restore) on boot.
ADMIN_EMAILS=you@example.com

# Only needed to publish Reels (Instagram fetches the video by public URL).
PUBLIC_BASE_URL=https://engine.example.com
